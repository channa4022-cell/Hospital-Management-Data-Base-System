    #3.1.bills table:before update
    use hospitaldb;
    delimiter //
    create trigger before_update_bills
    before update
    on bills
    for each row
    begin
	if new.amount < 0 then
    signal sqlstate'45000'
set message_text= "Bill amount cannot be negative";
end if;
end;

#2.rooms table
 use hospitaldb;
    delimiter //
    create trigger before_update_rooms
    before update
    on rooms
    for each row
    begin
	if new.R_capacity <= 0 then
    signal sqlstate'45000'
set message_text= "Room capacity must be greater than zero";
end if;
end;

#4.bills:after update
use hospitaldb;
create table bills_update(B_ID int primary key,
                          old_amount int,
                          new_amount int,
                          updated_on time);
	select * from bills_update;
    insert into bills_update values (401,2000,3000,now());
    
    delimiter //
    create trigger bills_history
    after update
    on bills
    for each row 
    begin
    if old.amount<> new.amount then
    insert into bills_update values(old.B_ID,OLD.amount,new.amount,now());
    end if;
    end;
    
    #5.before delete-back up patient data
     use hospitaldb;
     create table patient_backup(P_ID int primary key,
                                 P_Name varchar(20),
                                 P_Gender varchar(10),
                                 P_Age int,
                                 P_Mobileno varchar(10),
                                 P_DOB date);
	select * from patient_backup;
    alter table patient_backup
    add backup_time varchar (100);
    
    delimiter //
    create trigger before_delete_patient
    before delete 
    on patients 
    for each row
    begin
    insert into patient_backup values (old.P_ID,old.P_Name,old.P_Gender,old.P_Age,old.P_Mobileno,old.P_DOB,now());
    end;
    
    #2back_up records data
     use hospitaldb;
     create table records_backup(Record_No int primary key,
								 App_No int,
                                 Backup_update varchar(100));
		select * from records_backup;
        
        delimiter //
        create trigger before_delete_records
