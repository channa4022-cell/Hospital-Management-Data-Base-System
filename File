 #triggers
#1.bills table: before insert
use hospitaldb;
delimiter //
create trigger bill_results
before insert
on bills
for each row
begin
if new.amount > 0 then
signal sqlstate'45000'
set message_text= "Bill amount cannot be negative";
end if;
end;

