use HospitalDB;

create table bills (B_ID int primary key,
					P_ID int,
                    Amount int);
select * from bills;

use HospitalDB;

create table consults ( P_ID int,
						D_ID int,
                        Consult_Date date,
                        primary key (P_ID,D_ID,Consult_Date),
                        foreign key (P_ID) references patient (P_ID),
                        foreign key (D_ID) references doctors (D_ID));
select * from consults;

use HospitalDB;

create table Assigned ( P_ID int,
						R_ID int,
                        primary key (P_ID,R_ID),
                        foreign key (P_ID) references patient (P_ID),
                        foreign key (R_ID) references rooms (R_ID));
select * from assigned;

create table pays ( P_ID int,
					B_ID int,
                    primary key (P_ID,B_ID),
                    foreign key (P_ID) references patient (P_ID),
                    foreign key (B_ID) references bills (B_ID));
select * from pays;

use HospitalDB;

create table governs ( N_ID int,
					   R_ID int,
                       primary key(N_ID,R_ID),
                       foreign key (N_ID) references nurses (N_ID),
                       foreign key (R_ID) references rooms (R_ID));
select * from governs;

use HospitalDB;

create table maintains ( RCP_ID int,
						Record_No int,
                        primary key (RCP_ID,Record_No),
                        foreign key(RCP_ID) references receptionist (RCP_ID),
                        foreign key(Record_No) references records(Record_No));
select * from maintains;

